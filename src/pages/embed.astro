---
// pages/embed.astro
// Minimal iframe-embeddable page with only the offer form.
// Accessible at /embed/ – no header, footer, or tracking scripts.

export const prerender = true;

import AtluiFormOfferMobile from "../components/form-ui/AtluiFormOfferMobile.astro";
---

<!doctype html>
<html lang="de-CH">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Umzugsofferte anfordern</title>

    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-MBDTD2XG');</script>

    <!-- Google Analytics / Ads -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-0XGGB6GEL6"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-0XGGB6GEL6', { anonymize_ip: true });
      gtag('config', 'AW-17057503111');
    </script>

    <!-- Form logic -->
    <script src="/assets/atlui_form_mobile.js" defer></script>
    <script src="/assets/air-datepicker.js" defer></script>

    <style>
      * {
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        padding: 0;
        background: transparent;
        font-family: Roboto, sans-serif;
        display: flex;
        justify-content: center;
        align-items: flex-start;
      }
    </style>
  </head>

  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MBDTD2XG"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

    <AtluiFormOfferMobile />
  </body>
</html>
