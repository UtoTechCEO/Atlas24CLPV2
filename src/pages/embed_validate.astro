---
// pages/embed_validate.astro
// Minimal iframe-embeddable variant of the phone verification step.
// Accessible at /embed_validate/ – no header, footer, or tracking scripts.

export const prerender = true;

import AtluiFormVerificationEmbed from "../components/AtluiFormVerificationEmbed.astro";
---

<!doctype html>
<html lang="de-CH">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>SMS bestätigen – Atlas24</title>

    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-MBDTD2XG');</script>

    <!-- Google Analytics / Ads + Conversion -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-0XGGB6GEL6"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-0XGGB6GEL6', { anonymize_ip: true });
      gtag('config', 'AW-17057503111');
      gtag('event', 'conversion', {
        send_to: 'AW-17057503111',
        value: 200,
        currency: 'CHF'
      });
    </script>

    <!-- Verification form logic -->
    <script src="/assets/atlui_form_verification_V2.js" defer></script>

    <style>
      * {
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        padding: 0;
        background: transparent;
        font-family: Roboto, sans-serif;
      }
    </style>
  </head>

  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MBDTD2XG"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

    <main>
      <AtluiFormVerificationEmbed />
      <div id="two-fa-feedback"></div>
    </main>
  </body>
</html>
